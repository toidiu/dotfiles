# grep
function psgrep() {
  echo "grep for: --- $1 ---"
  ps aux | grep $1 | grep -v grep
}
# opencode
function ak-openvoice() {
  local port
  # Generate a random port in the user port range (1025-65535)
  port=$(( (RANDOM % 64511) + 3333 ))
  echo "New session on port: $port"

  tmux split-window -v "echo 'opencode server: http://127.0.0.1:${port}/\n'; opencode-voice --no-push-to-talk --port $port";
  opencode --port $port;
  echo "done"
}

