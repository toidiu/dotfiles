{
  "_coc.preferences.formatOnSaveFiletypes": ["rust"],

  "languageserver": {
    "clangd": {
      "command": "clangd",
      "rootPatterns": [ "CMakeLists.txt" ],
      "filetypes": [ "c", "cc", "cpp", "c++" ]
    },
    "lua": {}
  },
    "suggest.floatConfig": {
      "maxWidth": 50,
      "border": true,
      "rounded": true,
      "highlight": "CocCustomPopup",
      "borderhighlight": "CocCustomPopupBorder"
    },
  "inlayHint.enable": "false"
}
